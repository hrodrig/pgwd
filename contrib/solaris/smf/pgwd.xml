<?xml version="1.0"?>
<!DOCTYPE service_bundle SYSTEM "/usr/share/lib/xml/dtd/service_bundle.dtd.1">
<service_bundle type='manifest' name='pgwd'>
  <service name='application/pgwd' type='service' version='1'>
    <create_default_instance enabled='false'/>
    <single_instance/>

    <dependency name='multi-user' type='service' grouping='require_all' restart_on='none'>
      <service_fmri value='svc:/milestone/multi-user'/>
    </dependency>

    <exec_method type='method' name='start'
      exec='/lib/svc/method/pgwd %m'
      timeout_seconds='60'/>

    <exec_method type='method' name='stop'
      exec=':kill'
      timeout_seconds='30'/>

    <property_group name='startd' type='framework'>
      <propval name='duration' type='astring' value='contract'/>
    </property_group>

    <template>
      <common_name>
        <loctext xml:lang='C'>Postgres Watch Dog</loctext>
      </common_name>
    </template>
  </service>
</service_bundle>
