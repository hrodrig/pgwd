# Ignore everything by default (including dotfiles).
# Only what is explicitly allowed below is tracked.

*
.*
!.gitignore
!.dockerignore
!.agents/
!.agents/**
!.cursor/
!.cursor/rules/
!.cursor/rules/*.mdc
!AGENTS.md
!README.md
!SECURITY.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!CHANGELOG.md
!VERSION
!LICENSE
!Makefile
!.goreleaser.yaml
!Dockerfile
!Dockerfile.release
!go.mod
!go.sum
!cmd/
!cmd/**
!internal/
!internal/**
!contrib/
!contrib/**
!tools/
!tools/**
!scripts/
!scripts/**
!docs/
!docs/***
!testing/
!testing/**
!.github/
!.github/**
# CodeQL local run (database and results; do not commit)
codeql-db/
codeql-results.sarif

# Generated man page (created by goreleaser before hook)
contrib/man/man1/pgwd.1.gz

# Never track macOS metadata
.DS_Store
**/.DS_Store
